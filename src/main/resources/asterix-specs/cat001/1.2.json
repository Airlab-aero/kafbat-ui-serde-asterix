{
  "category": 1,
  "edition": "1.2",
  "name": "Transmission of Monoradar Data Target Reports",
  "date": "2011-08-01",
  "uap": {
    "type": "multi",
    "variants": {
      "case": [
        "0: plot",
        "1: track"
      ]
    }
  },
  "items": {
    "I010": {
      "title": "Data Source Identifier",
      "rule": {
        "type": "Group",
        "items": [
          {
            "type": "Item",
            "name": "SAC",
            "title": "System Area Code",
            "rule": {
              "type": "Element",
              "size": 8,
              "content": {
                "type": "Raw"
              }
            }
          },
          {
            "type": "Item",
            "name": "SIC",
            "title": "System Identification Code",
            "rule": {
              "type": "Element",
              "size": 8,
              "content": {
                "type": "Raw"
              }
            }
          }
        ]
      }
    },
    "I020": {
      "title": "Target Report Descriptor",
      "rule": {
        "type": "Extended",
        "groups": [
          [
            {
              "type": "Item",
              "name": "TYP",
              "title": "",
              "rule": {
                "type": "Element",
                "size": 1,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Plot",
                    "1": "Track"
                  }
                }
              }
            },
            {
              "type": "Item",
              "name": "SIM",
              "title": "",
              "rule": {
                "type": "Element",
                "size": 1,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Actual plot or track",
                    "1": "Simulated plot or track"
                  }
                }
              }
            },
            {
              "type": "Item",
              "name": "SSRPSR",
              "title": "Radar Detection in Last Antenna Scan",
              "rule": {
                "type": "Element",
                "size": 2,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "No detection",
                    "1": "Sole primary detection",
                    "2": "Sole secondary detection",
                    "3": "Combined primary and secondary detection"
                  }
                }
              }
            },
            {
              "type": "Item",
              "name": "ANT",
              "title": "",
              "rule": {
                "type": "Element",
                "size": 1,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Target report from antenna 1",
                    "1": "Target report from antenna 2"
                  }
                }
              }
            },
            {
              "type": "Item",
              "name": "SPI",
              "title": "",
              "rule": {
                "type": "Element",
                "size": 1,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Default",
                    "1": "Special Position Identification"
                  }
                }
              }
            },
            {
              "type": "Item",
              "name": "RAB",
              "title": "",
              "rule": {
                "type": "Element",
                "size": 1,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Default",
                    "1": "Plot or track from a fixed transponder"
                  }
                }
              }
            }
          ],
          [
            {
              "type": "Item",
              "name": "TST",
              "title": "",
              "rule": {
                "type": "Element",
                "size": 1,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Default",
                    "1": "Test target indicator"
                  }
                }
              }
            },
            {
              "type": "Item",
              "name": "DS1DS2",
              "title": "Radar Detection in Last Antenna Scan",
              "rule": {
                "type": "Element",
                "size": 2,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Default",
                    "1": "Unlawful interference (code 7500)",
                    "2": "Radio-communication failure (code 7600)",
                    "3": "Emergency (code 7700)"
                  }
                }
              }
            },
            {
              "type": "Item",
              "name": "ME",
              "title": "",
              "rule": {
                "type": "Element",
                "size": 1,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Default",
                    "1": "Military emergency"
                  }
                }
              }
            },
            {
              "type": "Item",
              "name": "MI",
              "title": "",
              "rule": {
                "type": "Element",
                "size": 1,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Default",
                    "1": "Military identification"
                  }
                }
              }
            },
            {
              "type": "Spare",
              "size": 2
            }
          ]
        ]
      }
    },
    "I030": {
      "title": "Warning/Error Conditions",
      "rule": {
        "type": "Repetitive",
        "repSize": 0,
        "fxMode": true,
        "rule": {
          "type": "Element",
          "size": 7,
          "content": {
            "type": "Table",
            "values": {
              "0": "No warning nor error condition",
              "1": "Garbled reply",
              "2": "Reflection",
              "3": "Sidelobe reply",
              "4": "Split plot",
              "5": "Second time around reply",
              "6": "Angels",
              "7": "Terrestrial vehicles",
              "64": "Possible wrong code in Mode-3/A",
              "65": "Possible wrong altitude information, transmitted when the Code C credibility check fails together with the Mode-C code in binary notation",
              "66": "Possible phantom MSSR plot",
              "80": "Fixed PSR plot",
              "81": "Slow PSR plot",
              "82": "Low quality PSR plot"
            }
          }
        }
      }
    },
