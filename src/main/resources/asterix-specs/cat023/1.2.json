{
  "category": 23,
  "edition": "1.2",
  "name": "CNS/ATM Ground Station and Service Status Reports",
  "date": "2009-03-01",
  "uap": {
    "type": "flat",
    "items": [
      "I010",
      "I000",
      "I015",
      "I070",
      "I100",
      "I101",
      "I200",
      "I110",
      "I120",
      null,
      null,
      null,
      "RE",
      "SP"
    ]
  },
  "items": {
    "I000": {
      "title": "Report Type",
      "rule": {
        "type": "Element",
        "size": 8,
        "content": {
          "type": "Table",
          "values": {
            "1": "Ground station status report",
            "2": "Service status report",
            "3": "Service statistics report"
          }
        }
      }
    },
    "I010": {
      "title": "Data Source Identifier",
      "rule": {
        "type": "Group",
        "items": [
          {
            "type": "Item",
            "name": "SAC",
            "title": "System Area Code",
            "rule": {
              "type": "Element",
              "size": 8,
              "content": {
                "type": "Raw"
              }
            }
          },
          {
            "type": "Item",
            "name": "SIC",
            "title": "System Identification Code",
            "rule": {
              "type": "Element",
              "size": 8,
              "content": {
                "type": "Raw"
              }
            }
          }
        ]
      }
    },
    "I015": {
      "title": "Service Type and Identification",
      "rule": {
        "type": "Group",
        "items": [
          {
            "type": "Item",
            "name": "SID",
            "title": "Service Identification",
            "rule": {
              "type": "Element",
              "size": 4,
              "content": {
                "type": "Raw"
              }
            }
          },
          {
            "type": "Item",
            "name": "STYP",
            "title": "Type of Service",
            "rule": {
              "type": "Element",
              "size": 4,
              "content": {
                "type": "Table",
                "values": {
                  "1": "ADS-B VDL4",
                  "2": "ADS-B Ext Squitter",
                  "3": "ADS-B UAT",
                  "4": "TIS-B VDL4",
                  "5": "TIS-B Ext Squitter",
                  "6": "TIS-B UAT",
                  "7": "FIS-B VDL4",
                  "8": "GRAS VDL4",
                  "9": "MLT"
                }
              }
            }
          }
        ]
      }
    },
    "I070": {
      "title": "Time of Day",
      "rule": {
        "type": "Element",
        "size": 24,
        "content": {
          "type": "Quantity",
          "signed": false,
          "lsb": 0.0078125,
          "unit": "s"
        }
      }
    },
    "I100": {
      "title": "Ground Station Status",
      "rule": {
        "type": "Extended",
        "groups": [
          [
            {
              "type": "Item",
              "name": "NOGO",
              "title": "Operational Release Status of the Data",
              "rule": {
                "type": "Element",
                "size": 1,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Data is released for operational use",
                    "1": "Data must not be used operationally"
                  }
                }
              }
            },
            {
              "type": "Item",
              "name": "ODP",
              "title": "Data Processor Overload Indicator",
              "rule": {
                "type": "Element",
                "size": 1,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Default, no overload",
                    "1": "Overload in DP"
                  }
                }
              }
            },
            {
              "type": "Item",
              "name": "OXT",
              "title": "Ground Interface Data Communications Overload",
              "rule": {
                "type": "Element",
                "size": 1,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Default, no overload",
                    "1": "Overload in transmission subsystem"
                  }
                }
              }
            },
            {
              "type": "Item",
              "name": "MSC",
              "title": "Monitoring System Connected Status",
              "rule": {
                "type": "Element",
                "size": 1,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Monitoring system not connected or unknown",
                    "1": "Monitoring system connected"
                  }
                }
              }
            },
            {
              "type": "Item",
              "name": "TSV",
              "title": "Time Source Validity",
              "rule": {
                "type": "Element",
                "size": 1,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Valid",
                    "1": "Invalid"
                  }
                }
              }
            },
            {
              "type": "Item",
              "name": "SPO",
              "title": "Indication of Spoofing Attack",
              "rule": {
                "type": "Element",
                "size": 1,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "No spoofing detected",
                    "1": "Potential spoofing attack"
                  }
                }
              }
            },
            {
              "type": "Item",
              "name": "RN",
              "title": "Renumbering Indication for Track ID",
              "rule": {
                "type": "Element",
                "size": 1,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Default",
                    "1": "Track numbering has restarted"
                  }
                }
              }
            }
          ],
          [
            {
              "type": "Item",
              "name": "GSSP",
              "title": "Ground Station Status Reporting Period",
              "rule": {
                "type": "Element",
                "size": 7,
                "content": {
                  "type": "Quantity",
                  "signed": false,
                  "lsb": 1.0,
                  "unit": "s"
                }
              }
            }
          ]
        ]
      }
    },
    "I101": {
      "title": "Service Configuration",
      "rule": {
        "type": "Extended",
        "groups": [
          [
            {
              "type": "Item",
              "name": "RP",
              "title": "Report Period for Category 021 Reports",
              "rule": {
                "type": "Element",
                "size": 8,
                "content": {
                  "type": "Quantity",
                  "signed": false,
                  "lsb": 0.5,
                  "unit": "s"
                }
              }
            },
            {
              "type": "Item",
              "name": "SC",
              "title": "Service Class",
              "rule": {
                "type": "Element",
                "size": 3,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "No information",
                    "1": "NRA class",
                    "2": "Reserved for future use",
                    "3": "Reserved for future use",
                    "4": "Reserved for future use",
                    "5": "Reserved for future use",
                    "6": "Reserved for future use",
                    "7": "Reserved for future use"
                  }
                }
              }
            },
            {
              "type": "Spare",
              "size": 4
            }
          ],
          [
            {
              "type": "Item",
              "name": "SSRP",
              "title": "Service Status Reporting Period",
              "rule": {
                "type": "Element",
                "size": 7,
                "content": {
                  "type": "Quantity",
                  "signed": false,
                  "lsb": 1.0,
                  "unit": "s"
                }
              }
            }
          ]
        ]
      }
    },
    "I110": {
      "title": "Service Status",
      "rule": {
        "type": "Extended",
        "groups": [
          [
            {
              "type": "Spare",
              "size": 4
            },
            {
              "type": "Item",
              "name": "STAT",
              "title": "Status of the Service",
              "rule": {
                "type": "Element",
                "size": 3,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Unknown",
                    "1": "Failed",
                    "2": "Disabled",
                    "3": "Degraded",
                    "4": "Normal",
                    "5": "Initialisation"
                  }
                }
              }
            }
          ]
        ]
      }
    },
    "I120": {
      "title": "Service Statistics",
      "rule": {
        "type": "Repetitive",
        "repSize": 1,
        "fxMode": false,
        "rule": {
          "type": "Group",
          "items": [
            {
              "type": "Item",
              "name": "TYPE",
              "title": "Type of Report Counter",
              "rule": {
                "type": "Element",
                "size": 8,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "Number of unknown messages received",
                    "1": "Number of too old messages received",
                    "2": "Number of failed message conversions",
                    "3": "Total Number of messages received",
                    "4": "Total Number of messages transmitted",
                    "20": "Number of TIS-B management messages received",
                    "21": "Number of Basic messages received",
                    "22": "Number of High Dynamic messages received",
                    "23": "Number of Full Position messages received",
                    "24": "Number of Basic Ground messages received",
                    "25": "Number of TCP messages received",
                    "26": "Number of UTC time messages received",
                    "27": "Number of Data messages received",
                    "28": "Number of High Resolution messages received",
                    "29": "Number of Aircraft Target Airborne messages received",
                    "30": "Number of Aircraft Target Ground messages received",
                    "31": "Number of Ground Vehicle Target messages received",
                    "32": "Number of 2 slots TCP messages received"
                  }
                }
              }
            },
            {
              "type": "Item",
              "name": "REF",
              "title": "Reference from which the Messages Are Countered",
              "rule": {
                "type": "Element",
                "size": 1,
                "content": {
                  "type": "Table",
                  "values": {
                    "0": "From midnight",
                    "1": "From the last report"
                  }
                }
              }
            },
            {
              "type": "Spare",
              "size": 7
            },
            {
              "type": "Item",
              "name": "CV",
              "title": "32-bit Counter Value",
              "rule": {
                "type": "Element",
                "size": 32,
                "content": {
                  "type": "Raw"
                }
              }
            }
          ]
        }
      }
    },
    "I200": {
      "title": "Operational Range",
      "rule": {
        "type": "Element",
        "size": 8,
        "content": {
          "type": "Quantity",
          "signed": false,
          "lsb": 1.0,
          "unit": "NM"
        }
      }
    },
    "RE": {
      "title": "Reserved Expansion Field",
      "rule": {
        "type": "Explicit"
      }
    },
    "SP": {
      "title": "Special Purpose Field",
      "rule": {
        "type": "Explicit"
      }
    }
  }
}